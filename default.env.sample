# default.env.sample
# Copy to default.env and adjust values before starting the stack.
# This file is sourced by composemgr and all variables are exported.

# Create a random secret
# openssl rand -hex 8

# create a random password
# head -n50 '/dev/random' | tr -dc 'a-zA-Z0-9[!@-]' | tr -d '[:space:]\042\047\134' | fold -w 32 | head -n 1

# create a hashed password
# head -n128 /dev/urandom|tr -dc 'A-Za-z0-9' | head -c 32 | openssl passwd -1 -salt $(openssl rand -base64 6) --stdin

# create a bcrypt password
# htpasswd -nbBC 9 pass pass|sed 's|pass:||g'

